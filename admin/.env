# admin/.env.example

# API Configuration
VITE_API_URL=http://localhost:5000/api

# Environment
VITE_ENV=development
VITE_APP_VERSION=1.0.0

# Site Configuration
VITE_SITE_NAME=CorePress CMS
VITE_SITE_DESCRIPTION=Modern Headless Content Management System
VITE_DEFAULT_THEME=light

# Analytics (Optional)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FB_PIXEL_ID=XXXXXXXXXX
VITE_CLARITY_ID=XXXXXXXXXX

# Error Tracking (Optional)
VITE_SENTRY_DSN=https://xxxxxx@xxxxxx.ingest.sentry.io/xxxxxx

# Features
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PWA=true

# Upload Limits
VITE_MAX_FILE_SIZE=10485760
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,application/pdf