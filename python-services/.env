# python-services/.env
ENV=development
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Image Optimization
MAX_IMAGE_SIZE=52428800
DEFAULT_IMAGE_QUALITY=80
ALLOWED_IMAGE_FORMATS=jpeg,png,webp,avif

# Spam Detection
SPAM_THRESHOLD=30